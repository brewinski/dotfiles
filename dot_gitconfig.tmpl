# Default identity — github values used as fallback outside managed directories
[user]
    name = {{ .git_github_name }}
    email = {{ .git_github_email }}
    signingkey = {{ onepasswordRead .git_signing_key_ref }}

[gpg]
    format = ssh

[gpg "ssh"]
    program = {{ if eq .chezmoi.os "darwin" }}/Applications/1Password.app/Contents/MacOS/op-ssh-sign{{ else }}op-ssh-sign{{ end }}

[commit]
    gpgsign = true

[core]
    excludesFile = ~/.gitignore_global
    autocrlf = input
    pager = delta

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[alias]
    lg = log --oneline --graph --decorate --all
    st = status -sb
    co = checkout
    br = branch

[includeIf "gitdir:~/github/"]
    path = ~/.gitconfig-github

[includeIf "gitdir:~/gitea/"]
    path = ~/.gitconfig-gitea

[includeIf "gitdir:~/Development/"]
    path = ~/.gitconfig-work
