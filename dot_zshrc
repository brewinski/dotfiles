alias v=nvim
alias vim=nvim
alias vi=nvim
alias cat="bat"
alias ls="eza --icons"
alias ll="eza -la --icons --git"
alias tree="eza --tree --icons"

export EDITOR=nvim
export VISUAL=nvim

# History
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY

# Homebrew
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Rust - rustup is keg-only on macOS so it needs its own PATH entry
[[ -d "/opt/homebrew/opt/rustup/bin" ]] && export PATH="/opt/homebrew/opt/rustup/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"

# Rancher Desktop docker compat layer
export PATH="$HOME/.rd/bin:$PATH"

# zsh plugins
[[ -f $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
    source $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[[ -f $HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
    source $HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# fzf
[[ -f $HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh ]] && \
    source $HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh
[[ -f $HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh ]] && \
    source $HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh

# zoxide
eval "$(zoxide init zsh)"

# gcloud
[[ -f $HOMEBREW_PREFIX/Caskroom/gcloud-cli/current/google-cloud-sdk/path.zsh.inc ]] && \
    source $HOMEBREW_PREFIX/Caskroom/gcloud-cli/current/google-cloud-sdk/path.zsh.inc
[[ -f $HOMEBREW_PREFIX/Caskroom/gcloud-cli/current/google-cloud-sdk/completion.zsh.inc ]] && \
    source $HOMEBREW_PREFIX/Caskroom/gcloud-cli/current/google-cloud-sdk/completion.zsh.inc

# Source all custom functions
for func in "$HOME/.config/zsh/functions/"*; do
    source "$func"
done

# Starship prompt
eval "$(starship init zsh)"
